{
  "manifest_version": 3,
  "name": "PixmaxHub Plug",
  "version": "1.3.5",
  "description": "Add Pixmax canvas helpers, Eagle import, and a shared team review board.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://app.pixmax.cn/*",
    "https://api.github.com/*",
    "https://codeload.github.com/*",
    "https://raw.githubusercontent.com/*",
    "http://localhost:41595/*",
    "http://127.0.0.1:41595/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.pixmax.cn/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://app.pixmax.cn/*"
      ],
      "js": [
        "relay.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PixmaxHub Plug"
  }
}
